          "definition": "CREATE OR REPLACE FUNCTION public.close_expired_auction(p_auction_id uuid)\n RETURNS json\n LANGUAGE plpgsql\n SECURITY DEFINER\nAS $function$\nDECLARE\n    v_auction RECORD;\n    v_seller_has_sticker BOOLEAN;\nBEGIN\n    -- 1) Bloquear y obtener la subasta para procesar el cierre\n    SELECT *\n      INTO v_auction\n      FROM public.auctions\n     WHERE id = p_auction_id\n       AND status = 'active'\n       AND expires_at <= NOW()\n     FOR UPDATE;\n\n    IF NOT FOUND THEN\n        RETURN json_build_object('success', false, 'message', 'La subasta no existe, ya fue cerrada o aún no ha expirado.');\n    END IF;\n\n    -- CASE A: Nadie pujó\n    IF v_auction.highest_bidder_id IS NULL THEN\n        UPDATE public.auctions\n           SET status = 'no_bids'\n         WHERE id = p_auction_id;\n\n        RETURN json_build_object('success', true, 'message', 'Subasta cerrada sin ofertas. El cromo sigue siendo del dueño.');\n    END IF;\n\n    -- CASE B: Tenemos ganador\n\n    -- 1) Verificar que el vendedor todavía tenga el cromo disponible\n    SELECT EXISTS (\n        SELECT 1\n          FROM public.user_stickers\n         WHERE user_id = v_auction.seller_id\n           AND sticker_id = v_auction.sticker_id\n           AND quantity > 0\n    ) INTO v_seller_has_sticker;\n\n    IF NOT v_seller_has_sticker THEN\n        -- Devolver monedas al ganador (no había devolución previa en close)\n        UPDATE public.user_profiles\n           SET coins = coins + v_auction.highest_bid\n         WHERE user_id = v_auction.highest_bidder_id;\n\n        UPDATE public.auctions\n           SET status = 'cancelled'\n         WHERE id = p_auction_id;\n\n        RETURN json_build_object('success', false, 'message', 'Error: El vendedor ya no posee el cromo. Subasta cancelada y monedas devueltas.');\n    END IF;\n\n    -- 2) Transferir el cromo\n    UPDATE public.user_stickers\n       SET quantity = quantity - 1\n     WHERE user_id = v_auction.seller_id\n       AND sticker_id = v_auction.sticker_id\n       AND quantity > 0;\n\n    INSERT INTO public.user_stickers (user_id, sticker_id, quantity)\n    VALUES (v_auction.highest_bidder_id, v_auction.sticker_id, 1)\n    ON CONFLICT (user_id, sticker_id)\n    DO UPDATE SET quantity = user_stickers.quantity + 1;\n\n    -- 3) Transferir monedas al vendedor\n    UPDATE public.user_profiles\n       SET coins = coins + v_auction.highest_bid\n     WHERE user_id = v_auction.seller_id;\n\n    -- 4) Marcar la subasta como finalizada\n    UPDATE public.auctions\n       SET status = 'finished'\n     WHERE id = p_auction_id;\n\n    RETURN json_build_object('success', true, 'message', '¡Subasta finalizada con éxito! Cromo y monedas transferidos.');\nEND;\n$function$\n",
