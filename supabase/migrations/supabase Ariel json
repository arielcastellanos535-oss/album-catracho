          "definition": "CREATE OR REPLACE FUNCTION public.accept_trade_offer(offer_code text, accepting_user_id uuid)\n RETURNS json\n LANGUAGE plpgsql\n SECURITY DEFINER\nAS $function$\nDECLARE\n    v_offer RECORD;\n    v_has_wanted_sticker BOOLEAN;\nBEGIN\n    -- 1) Bloquear y buscar la oferta pendiente\n    SELECT * INTO v_offer\n    FROM public.trade_offers\n    WHERE id = offer_code AND status = 'pending'\n    FOR UPDATE;\n\n    IF NOT FOUND THEN\n        RETURN json_build_object('success', false, 'message', 'El código de intercambio no existe o ya expiró.');\n    END IF;\n\n    -- No puedes intercambiar contigo mismo\n    IF v_offer.user_id = accepting_user_id THEN\n        RETURN json_build_object('success', false, 'message', 'No puedes aceptar tu propio intercambio.');\n    END IF;\n\n    -- 2) Verificar que el aceptante tiene el sticker que el ofertante busca\n    SELECT EXISTS (\n        SELECT 1\n        FROM public.user_stickers\n        WHERE user_id = accepting_user_id\n          AND sticker_id = v_offer.sticker_id_wanted\n          AND quantity > 0\n    ) INTO v_has_wanted_sticker;\n\n    IF NOT v_has_wanted_sticker THEN\n        RETURN json_build_object('success', false, 'message', 'No tienes el cromo que este jugador está buscando.');\n    END IF;\n\n    -- 3) Ajustar cantidades (ofertante recibe el wanted; entrega el offered)\n\n    -- Al ofertante: +1 del que quería\n    INSERT INTO public.user_stickers (user_id, sticker_id, quantity)\n    VALUES (v_offer.user_id, v_offer.sticker_id_wanted, 1)\n    ON CONFLICT (user_id, sticker_id)\n    DO UPDATE SET quantity = public.user_stickers.quantity + 1;\n\n    -- Al aceptante: -1 del que entrega (el wanted)\n    UPDATE public.user_stickers\n    SET quantity = quantity - 1\n    WHERE user_id = accepting_user_id\n      AND sticker_id = v_offer.sticker_id_wanted\n      AND quantity > 0;\n\n    -- Al aceptante: +1 del que recibe (el offered)\n    INSERT INTO public.user_stickers (user_id, sticker_id, quantity)\n    VALUES (accepting_user_id, v_offer.sticker_id_offered, 1)\n    ON CONFLICT (user_id, sticker_id)\n    DO UPDATE SET quantity = public.user_stickers.quantity + 1;\n\n    -- 4) Marcar oferta como completada\n    UPDATE public.trade_offers\n    SET status = 'completed'\n    WHERE id = offer_code\n      AND status = 'pending';\n\n    RETURN json_build_object('success', true, 'message', '¡Intercambio realizado con éxito!');\nEND;\n$function$\n",
